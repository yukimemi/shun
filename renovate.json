{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "merge-commit",
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates for npm deps",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge patch and minor updates for Rust crates",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Ignore webview2-com and windows-core — must stay in sync with Tauri's transitive versions",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["webview2-com", "windows-core"],
      "enabled": false
    }
  ]
}
